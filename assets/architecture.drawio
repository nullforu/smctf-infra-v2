        <mxCell id="FD22od7KxxAk7iYq8aAd-32" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;spacing=0;" value="It is possible to operate without using a NAT Gateway at all and rely solely on&amp;nbsp;&lt;div&gt;interface endpoints;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;however,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;this can actually be less cost-effective.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;&lt;div&gt;Therefore, in this architecture, we have configured endpoints only for&amp;nbsp;&lt;/div&gt;&lt;div&gt;S3, which are expected to generate relatively higher traffic.&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="360" x="760" y="564" as="geometry" />
        </mxCell>
